<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    HideSoftInputOnTapped="True"
    Shell.NavBarIsVisible="False"
    x:Class="BioscoopMAUI.Views.ShowtimesPage"
    x:DataType="viewModels:ShowtimesPageViewModel"
    x:Name="ShowtimesPageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:BioscoopMAUI.Controls"
    xmlns:models="clr-namespace:BioscoopMAUI.Models.DTOs;assembly=BioscoopMAUI.Models"
    xmlns:ui="clr-namespace:BioscoopMAUI.ViewModels.UI"
    xmlns:viewModels="clr-namespace:BioscoopMAUI.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid RowDefinitions="Auto,*">
        <controls:PageHeader
            Grid.Row="0"
            Style="{StaticResource PageHeaderStyle}"
            Subtitle="Find a screening by date and movie."
            Title="Screenings" />

        <Grid Grid.Row="1">
            <RefreshView
                Command="{Binding LoadShowtimesCommand}"
                IsRefreshing="{Binding IsPullRefreshing, Mode=OneWay}"
                IsVisible="{Binding ShowShowtimesList}">
                <ScrollView>
                    <VerticalStackLayout Margin="20,0,20,20" Spacing="0">
                        <controls:SurfacePanel
                            Margin="0,14,0,10"
                            Padding="12"
                            Style="{StaticResource SurfacePanelStyle}">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="1">
                                        <Label
                                            FontAttributes="Bold"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="15"
                                            Text="Filter screenings" />
                                        <Label
                                            FontSize="12"
                                            Text="Date, time, or movie"
                                            TextColor="{StaticResource TextMuted}" />
                                    </VerticalStackLayout>
                                    <Border
                                        BackgroundColor="{StaticResource Secondary}"
                                        Grid.Column="1"
                                        Padding="10,5"
                                        StrokeThickness="0"
                                        VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>
                                        <Label
                                            FontAttributes="Bold"
                                            FontFamily="OpenSansSemibold"
                                            FontSize="11"
                                            Text="{Binding Showtimes.Count, StringFormat='{0} shown'}"
                                            TextColor="{StaticResource PrimaryDark}" />
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                    <Border
                                        BackgroundColor="{StaticResource AppSurfaceElevated}"
                                        Padding="10,8"
                                        Stroke="{StaticResource AppStroke}"
                                        StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18" />
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsDateFilterExpanded}"
                                                TargetType="Border"
                                                Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                                                <Setter Property="Stroke" Value="{StaticResource Tertiary}" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleDateFilterCommand}" />
                                        </Border.GestureRecognizers>
                                        <VerticalStackLayout Spacing="1">
                                            <Label
                                                FontSize="11"
                                                Text="Date"
                                                TextColor="{StaticResource TextMuted}" />
                                            <Label
                                                FontAttributes="Bold"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="13"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding SelectedDateLabel}" />
                                        </VerticalStackLayout>
                                    </Border>

                                    <Border
                                        BackgroundColor="{StaticResource AppSurfaceElevated}"
                                        Grid.Column="1"
                                        Padding="10,8"
                                        Stroke="{StaticResource AppStroke}"
                                        StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18" />
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsTimeFilterExpanded}"
                                                TargetType="Border"
                                                Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                                                <Setter Property="Stroke" Value="{StaticResource Tertiary}" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleTimeFilterCommand}" />
                                        </Border.GestureRecognizers>
                                        <VerticalStackLayout Spacing="1">
                                            <Label
                                                FontSize="11"
                                                Text="Time"
                                                TextColor="{StaticResource TextMuted}" />
                                            <Label
                                                FontAttributes="Bold"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="13"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding SelectedTimeLabel}" />
                                        </VerticalStackLayout>
                                    </Border>
                                    <Border
                                        BackgroundColor="{StaticResource AppSurfaceElevated}"
                                        Grid.Column="2"
                                        Padding="10,8"
                                        Stroke="{StaticResource AppStroke}"
                                        StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18" />
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsMovieFilterExpanded}"
                                                TargetType="Border"
                                                Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                                                <Setter Property="Stroke" Value="{StaticResource Tertiary}" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleMovieFilterCommand}" />
                                        </Border.GestureRecognizers>
                                        <VerticalStackLayout Spacing="1">
                                            <Label
                                                AutomationId="ShowtimesMovieFilterToggle"
                                                FontSize="11"
                                                Text="Movie"
                                                TextColor="{StaticResource TextMuted}">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding ToggleMovieFilterCommand}" />
                                                </Label.GestureRecognizers>
                                            </Label>
                                            <Label
                                                FontAttributes="Bold"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="13"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding SelectedMovieLabel}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>

                                <VerticalStackLayout IsVisible="{Binding IsDateFilterExpanded}" Spacing="8">
                                    <HorizontalStackLayout BindableLayout.ItemsSource="{Binding DateFilterOptions}" Spacing="8">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="ui:ShowtimeFilterOption">
                                                <RadioButton
                                                    CheckedChanged="OnDateFilterCheckedChanged"
                                                    Content="{Binding Label}"
                                                    GroupName="DateFilter"
                                                    IsChecked="{Binding IsSelected}"
                                                    TextColor="{StaticResource TextPrimary}" />
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>

                                    <DatePicker
                                        BackgroundColor="Transparent"
                                        Date="{Binding SelectedCalendarDate}"
                                        MaximumDate="{Binding MaximumFilterDate}"
                                        MinimumDate="{Binding MinimumFilterDate}"
                                        TextColor="{StaticResource TextPrimary}" />
                                </VerticalStackLayout>

                                <HorizontalStackLayout
                                    BindableLayout.ItemsSource="{Binding TimeFilterOptions}"
                                    IsVisible="{Binding IsTimeFilterExpanded}"
                                    Spacing="8">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="ui:ShowtimeFilterOption">
                                            <RadioButton
                                                CheckedChanged="OnTimeFilterCheckedChanged"
                                                Content="{Binding Label}"
                                                GroupName="TimeFilter"
                                                IsChecked="{Binding IsSelected}"
                                                TextColor="{StaticResource TextPrimary}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </HorizontalStackLayout>

                                <SearchBar
                                    AutomationId="ShowtimesSearchBar"
                                    IsVisible="{Binding IsMovieFilterExpanded}"
                                    Margin="0,-4,0,0"
                                    Placeholder="Search by movie title..."
                                    SearchButtonPressed="OnMovieSearchButtonPressed"
                                    SearchCommand="{Binding SearchMovieCommand}"
                                    Text="{Binding PendingMovieSearchText, Mode=TwoWay}"
                                    TextChanged="OnMovieSearchTextChanged" />
                            </VerticalStackLayout>
                        </controls:SurfacePanel>

                        <controls:SurfacePanel
                            IsVisible="{Binding HasNoMatchingShowtimes}"
                            Margin="0,8,0,20"
                            Style="{StaticResource SurfacePanelStyle}">
                            <VerticalStackLayout Spacing="10">
                                <Label
                                    AutomationId="ShowtimesNoMatchesPanel"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="18"
                                    Text="No matching screenings" />
                                <Label Style="{StaticResource DescriptionLabelStyle}" Text="Try adjusting your filters or search term." />
                            </VerticalStackLayout>
                        </controls:SurfacePanel>

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Showtimes}" Spacing="0">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:FilmsOverviewDto">
                                    <Border Style="{StaticResource ShowtimeCardStyle}">
                                        <Border.Background>
                                            <LinearGradientBrush EndPoint="1,1">
                                                <GradientStop Color="{StaticResource AppSurface}" Offset="0" />
                                                <GradientStop Color="{StaticResource AppSurfaceElevated}" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding BindingContext.OpenShowtimeDetailsCommand, Source={x:Reference ShowtimesPageRoot}}" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="14">
                                            <Border
                                                HeightRequest="85"
                                                StrokeThickness="0"
                                                WidthRequest="60">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="12" />
                                                </Border.StrokeShape>
                                                <Grid>
                                                    <Grid.Background>
                                                        <LinearGradientBrush EndPoint="1,1">
                                                            <GradientStop Color="{StaticResource AppSurfaceElevated}" Offset="0" />
                                                            <GradientStop Color="{StaticResource Secondary}" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Grid.Background>
                                                    <Image Aspect="AspectFill" Source="{Binding PosterUrl}" />
                                                </Grid>
                                            </Border>

                                            <VerticalStackLayout
                                                Grid.Column="1"
                                                Spacing="5"
                                                VerticalOptions="Center">
                                                <Label Style="{StaticResource MovieCardTitleLabelStyle}" Text="{Binding Title}" />
                                                <Label
                                                    LineBreakMode="TailTruncation"
                                                    Style="{StaticResource MutedLabelStyle}"
                                                    Text="{Binding Genres}" />
                                                <HorizontalStackLayout Spacing="8">
                                                    <Label Style="{StaticResource MutedLabelStyle}" Text="{Binding DurationMinutes, StringFormat='{0} min'}" />
                                                    <Label Style="{StaticResource MutedLabelStyle}" Text="{Binding StartTime, StringFormat='{0:ddd d MMM}'}" />
                                                </HorizontalStackLayout>
                                                <Border
                                                    BackgroundColor="{StaticResource Secondary}"
                                                    HorizontalOptions="Start"
                                                    IsVisible="{Binding DiscountPercentage, Converter={StaticResource DiscountPercentageToBoolConverter}}"
                                                    Padding="9,4"
                                                    StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="14" />
                                                    </Border.StrokeShape>
                                                    <Label
                                                        FontAttributes="Bold"
                                                        FontFamily="OpenSansSemibold"
                                                        FontSize="11"
                                                        Text="{Binding DiscountPercentage, Converter={StaticResource DiscountPercentageToLabelConverter}}"
                                                        TextColor="{StaticResource PrimaryDark}" />
                                                </Border>
                                            </VerticalStackLayout>

                                            <Border
                                                BackgroundColor="{StaticResource Secondary}"
                                                Grid.Column="2"
                                                Padding="12,7"
                                                StrokeThickness="0"
                                                VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="16" />
                                                </Border.StrokeShape>
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontFamily="OpenSansSemibold"
                                                    FontSize="15"
                                                    Text="{Binding StartTime, StringFormat='{0:HH:mm}'}"
                                                    TextColor="{StaticResource PrimaryDark}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <Button
                            Command="{Binding LoadMoreCommand}"
                            IsVisible="{Binding HasMoreShowtimes}"
                            Margin="0,4,0,0"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Text="Load more" />
                    </VerticalStackLayout>
                </ScrollView>
            </RefreshView>

            <ActivityIndicator
                HeightRequest="44"
                HorizontalOptions="Center"
                IsRunning="{Binding IsInitialLoading}"
                IsVisible="{Binding IsInitialLoading}"
                VerticalOptions="Center"
                WidthRequest="44" />

            <RefreshView
                Command="{Binding LoadShowtimesCommand}"
                IsRefreshing="{Binding IsPullRefreshing, Mode=OneWay}"
                IsVisible="{Binding HasError}">
                <ScrollView>
                    <controls:SurfacePanel
                        Margin="20"
                        Style="{StaticResource SurfacePanelStyle}"
                        VerticalOptions="Center">
                        <VerticalStackLayout Spacing="14">
                            <Label
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="18"
                                Text="Something went wrong" />
                            <Label Style="{StaticResource DescriptionLabelStyle}" Text="{Binding ErrorMessage}" />
                            <Button Command="{Binding LoadShowtimesCommand}" Text="Try again" />
                        </VerticalStackLayout>
                    </controls:SurfacePanel>
                </ScrollView>
            </RefreshView>

            <RefreshView
                Command="{Binding LoadShowtimesCommand}"
                IsRefreshing="{Binding IsPullRefreshing, Mode=OneWay}"
                IsVisible="{Binding IsEmptyStateVisible}">
                <ScrollView>
                    <controls:SurfacePanel
                        Margin="20"
                        Style="{StaticResource SurfacePanelStyle}"
                        VerticalOptions="Center">
                        <VerticalStackLayout Spacing="10">
                            <Label
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="18"
                                Text="No screenings yet" />
                            <Label Style="{StaticResource DescriptionLabelStyle}" Text="Pull to refresh once screenings are available." />
                        </VerticalStackLayout>
                    </controls:SurfacePanel>
                </ScrollView>
            </RefreshView>
        </Grid>
    </Grid>
</ContentPage>