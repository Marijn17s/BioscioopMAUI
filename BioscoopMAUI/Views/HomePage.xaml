<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    Shell.NavBarIsVisible="False"
    x:Class="BioscoopMAUI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:BioscoopMAUI.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <ContentPage.Content>
        <Grid RowDefinitions="Auto,*">
            <controls:PageHeader
                Grid.Row="0"
                Style="{StaticResource PageHeaderStyle}"
                Subtitle="Welcome to our cinema."
                Title="Home" />
        </Grid>
    </ContentPage.Content>
</ContentPage>