<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    Shell.NavBarIsVisible="True"
    Title="Choose Seats"
    x:Class="BioscoopMAUI.Views.SeatSelectionPage"
    x:DataType="viewModels:SeatSelectionPageViewModel"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:controls="clr-namespace:BioscoopMAUI.Controls"
    xmlns:ui="clr-namespace:BioscoopMAUI.ViewModels.UI"
    xmlns:viewModels="clr-namespace:BioscoopMAUI.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="18">
                <VerticalStackLayout Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="28"
                        Text="Choose your seats"
                        TextColor="{StaticResource TextPrimary}" />
                    <Label Style="{StaticResource DescriptionLabelStyle}" Text="{Binding Subtitle}" />
                    <Label Style="{StaticResource MutedLabelStyle}" Text="{Binding RoomName}" />
                </VerticalStackLayout>

                <controls:SurfacePanel Style="{StaticResource SurfacePanelStyle}">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                Text="Tickets" />
                            <Label Style="{StaticResource MutedLabelStyle}" Text="Auto-suggest updates with the ticket amount." />
                        </VerticalStackLayout>
                        <Button
                            Command="{Binding DecreaseTicketCountCommand}"
                            Grid.Column="1"
                            IsEnabled="{Binding CanDecreaseTicketCount}"
                            Text="-" />
                        <Border
                            BackgroundColor="{StaticResource AppSurfaceElevated}"
                            Grid.Column="2"
                            HeightRequest="44"
                            StrokeThickness="0"
                            WidthRequest="58">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Entry
                                Completed="OnTicketCountEntryCompleted"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="16"
                                HorizontalTextAlignment="Center"
                                IsEnabled="{Binding CanEditTicketCount}"
                                Keyboard="Numeric"
                                Text="{Binding TicketCountText}"
                                TextColor="{StaticResource TextPrimary}"
                                Unfocused="OnTicketCountEntryUnfocused"
                                VerticalOptions="Center" />
                        </Border>
                        <Button
                            Command="{Binding IncreaseTicketCountCommand}"
                            Grid.Column="3"
                            IsEnabled="{Binding CanIncreaseTicketCount}"
                            Text="+" />
                        <Button
                            Clicked="OnApplyTicketCountClicked"
                            Grid.Column="4"
                            IsEnabled="{Binding CanEditTicketCount}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Text="Apply" />
                    </Grid>
                </controls:SurfacePanel>

                <Border
                    BackgroundColor="{StaticResource AppSurfaceElevated}"
                    HeightRequest="46"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Label
                        CharacterSpacing="9"
                        HorizontalOptions="Center"
                        Text="SCREEN"
                        TextColor="{StaticResource TextSecondary}"
                        VerticalOptions="Center" />
                </Border>

                <HorizontalStackLayout Spacing="16">
                    <HorizontalStackLayout Spacing="6">
                        <BoxView
                            BackgroundColor="#24A148"
                            CornerRadius="4"
                            HeightRequest="18"
                            WidthRequest="18" />
                        <Label Text="Available" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="6">
                        <BoxView
                            BackgroundColor="#D73A49"
                            CornerRadius="4"
                            HeightRequest="18"
                            WidthRequest="18" />
                        <Label Text="Occupied" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="6">
                        <BoxView
                            BackgroundColor="#FFC107"
                            CornerRadius="4"
                            HeightRequest="18"
                            WidthRequest="18" />
                        <Label Text="Selected" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                </HorizontalStackLayout>

                <Label Style="{StaticResource MutedLabelStyle}" Text="Swipe horizontally to move the seats." />

                <Grid ColumnDefinitions="70,*" ColumnSpacing="12">
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Rows}" Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="ui:SeatRowViewModel">
                                <Label
                                    HeightRequest="44"
                                    Style="{StaticResource MutedLabelStyle}"
                                    Text="{Binding RowNumber, StringFormat='Row {0}'}"
                                    VerticalTextAlignment="Center" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <ScrollView Grid.Column="1" Orientation="Horizontal">
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Rows}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="ui:SeatRowViewModel">
                                    <HorizontalStackLayout
                                        BindableLayout.ItemsSource="{Binding Seats}"
                                        HeightRequest="44"
                                        Spacing="6">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="ui:SeatOptionViewModel">
                                                <Border
                                                    BackgroundColor="{Binding BackgroundColor}"
                                                    HeightRequest="44"
                                                    StrokeThickness="0"
                                                    WidthRequest="44">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="8" />
                                                    </Border.StrokeShape>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectSeatCommand}" CommandParameter="{Binding .}" />
                                                    </Border.GestureRecognizers>
                                                    <Label
                                                        FontAttributes="Bold"
                                                        HorizontalOptions="Center"
                                                        Text="{Binding SeatNumber}"
                                                        TextColor="{Binding TextColor}"
                                                        VerticalOptions="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>

                <controls:SurfacePanel IsVisible="{Binding HasError}" Style="{StaticResource SurfacePanelStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label
                            FontAttributes="Bold"
                            FontFamily="OpenSansSemibold"
                            Text="Something went wrong" />
                        <Label Style="{StaticResource DescriptionLabelStyle}" Text="{Binding ErrorMessage}" />
                    </VerticalStackLayout>
                </controls:SurfacePanel>
            </VerticalStackLayout>
        </ScrollView>

        <controls:SurfacePanel
            Grid.Row="1"
            Margin="20"
            Style="{StaticResource SurfacePanelStyle}">
            <Grid
                ColumnDefinitions="*,Auto"
                RowDefinitions="Auto,Auto"
                RowSpacing="4">
                <VerticalStackLayout Spacing="2">
                    <Label
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        Text="{Binding PriceText}" />
                    <Label
                        IsVisible="{Binding HasDiscount}"
                        Style="{StaticResource MutedLabelStyle}"
                        Text="{Binding DiscountText}" />
                </VerticalStackLayout>
                <Button
                    Command="{Binding ConfirmCommand}"
                    Grid.Column="1"
                    IsEnabled="{Binding CanConfirm}"
                    Text="{Binding ConfirmButtonText}" />
            </Grid>
        </controls:SurfacePanel>

        <ActivityIndicator
            Grid.RowSpan="2"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center" />
    </Grid>
</ContentPage>