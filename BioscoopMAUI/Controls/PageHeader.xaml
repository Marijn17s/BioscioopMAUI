<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="BioscoopMAUI.Controls.PageHeader"
    x:Name="PageHeaderRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Spacing="12">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" RowDefinitions="Auto">
            <VerticalStackLayout
                Grid.Column="0"
                Spacing="4"
                VerticalOptions="Center">
                <Label
                    AutomationId="PageTitle"
                    x:Name="TitleLabel"
                    Style="{StaticResource PageHeaderTitleLabelStyle}"
                    Text="{Binding Title, Source={x:Reference PageHeaderRoot}}" />
                <Label
                    x:Name="SubtitleLabel"
                    IsVisible="False"
                    Style="{StaticResource PageHeaderSubtitleLabelStyle}"
                    Text="{Binding Subtitle, Source={x:Reference PageHeaderRoot}}" />
            </VerticalStackLayout>

            <ContentView
                x:Name="TrailingContentPresenter"
                Grid.Column="1"
                IsVisible="False"
                VerticalOptions="Start" />

            <Border
                x:Name="BadgeBorder"
                BackgroundColor="{StaticResource Secondary}"
                Grid.Column="1"
                IsVisible="False"
                Padding="12,6"
                StrokeThickness="0"
                VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Label
                    x:Name="BadgeLabel"
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    FontSize="12"
                    TextColor="{StaticResource PrimaryDark}" />
            </Border>
        </Grid>

        <ContentView x:Name="BottomContentPresenter" IsVisible="False" />
    </VerticalStackLayout>
</ContentView>